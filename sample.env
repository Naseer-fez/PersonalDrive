# Absolute or relative path where uploaded files will be stored. (Required)
DestinationFolder=
# Path to store user-specific JSON directory structures. (Required)
Userfolder=
# Chunk size (in MB) for reading/writing files during transfer. (Required)
size=
# Default storage quota allocated to new users (in GB). (Required)
basic=
# Flask application secret key. (Required)
secret=
# Unused/deprecated backend variable
backedn=
# Secret key used for signing JWTs. (Required)
jwt=
# Lifespan of the JWT access token (in days). (Required)
jwtduration=
# SQLAlchemy database URI (defaults to sqlite:///users.db). (Optional)
Database=
# SMTP email address for password recovery. (Optional)
email=
# SMTP password/app password. (Optional)
sendemail= 
# Path for storing rate limiter state data. (Required)
ratelimiter=
# The path to save the ratelimiter data (Optional)
FrontendURL=
# Base URL for the backend (used for generating share links). (Optional)
URL=