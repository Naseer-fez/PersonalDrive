# Flask application secret key used for session signing and encryption. (Required)
secret=

# Legacy configuration variable (Keep empty).
backedn=""

# Secret key used for signing and verifying JSON Web Tokens (JWT) for user authentication. (Required)
jwt=

# Database connection URI. Defaults to sqlite:///users.db if empty.
Database=

# SMTP email address used for sending password recovery emails (e.g. your Brevo sender email). (Optional)
EmailAPi=

# SMTP server password or API key for authentication (e.g. your Brevo SMTP key). (Optional)
sendemail=

# Allowed origins for CORS (Cross-Origin Resource Sharing). Set to '*' to allow all client websites.
FrontendURL=*

# The base URL of the backend API, used for generating shareable file links.
URL=http://localhost:5174